# Copia este archivo a .env y completa los valores reales.
# El archivo .env NO se versiona (está en .gitignore).

# === Azure Blob Storage (blob-reader.py) ===
# Elige UN método de autenticación:

# MÉTODO 1: Connection String (recomendado)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# MÉTODO 3: SAS Token (alternativa)
# AZURE_STORAGE_SAS_TOKEN=

# Contenedor por defecto (opcional)
AZURE_STORAGE_CONTAINER=

# === Service Principal de Azure (azure-read.py, read-google-drive.py) ===
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_READ_ACCOUNT_NAME=
AZURE_READ_CONTAINER=media

# === ArcGIS OAuth (arcgis-csv.py, arcgis-json.py) ===
ARCGIS_CLIENT_ID=
ARCGIS_CLIENT_SECRET=

# === Google Drive -> Azure (read-google-drive.py) ===
# Reutiliza AZURE_TENANT_ID / AZURE_CLIENT_ID / AZURE_CLIENT_SECRET (mismo service principal)
GDRIVE_SERVICE_ACCOUNT_FILE=driveread-478714-8c043125ed61.json
GDRIVE_AZURE_ACCOUNT_NAME=stpnis
GDRIVE_AZURE_CONTAINER=testdsci

# === SMTP Office 365 (simple_smtp.py) ===
SMTP_USERNAME=
SMTP_PASSWORD=

# === Renhacemos API (job-completar-pendientes.py) ===
RENHACEMOS_JWT_TOKEN=
